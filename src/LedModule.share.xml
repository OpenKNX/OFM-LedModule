<?xml version="1.0" encoding="utf-8"?>
<?xml-model href="../../../../Organization/knxprod-support/knx_project_20/knx-editor.xsd" type="application/xml" schematypens="http://www.w3.org/2001/XMLSchema"?>
<KNX xmlns:op="http://github.com/OpenKNX/OpenKNXproducer" xmlns="http://knx.org/xml/project/20" CreatedBy="KNX MT" ToolVersion="5.1.255.16695">

  <ManufacturerData>
    <Manufacturer>
      <ApplicationPrograms>
        <ApplicationProgram>

          <op:part href="ChannelActivation.part.xml" name="LED_SC" instances="16">
            <op:param name="%Cn%" value="1" increment="1" digits="2" /> <!-- Channel number -->
            <op:param name="%TT%" value="21" increment="0" digits="2" /> <!-- Module Type -->
            <op:param name="%id%" value="001" increment="0" digits="3" /> <!-- Ref ID Base-->
          </op:part>

          <op:part href="ChannelActivation.part.xml" name="LED_TW" instances="8">
            <op:param name="%Cn%" value="1" increment="1" digits="2" /> <!-- Channel number -->
            <op:param name="%TT%" value="22" increment="0" digits="2" /> <!-- Module Type -->
            <op:param name="%id%" value="001" increment="0" digits="3" /> <!-- Ref ID Base-->
          </op:part>

          <op:part href="ChannelActivation.part.xml" name="LED_RGB" instances="5">
            <op:param name="%Cn%" value="1" increment="1" digits="2" /> <!-- Channel number -->
            <op:param name="%TT%" value="23" increment="0" digits="2" /> <!-- Module Type -->
            <op:param name="%id%" value="001" increment="0" digits="3" /> <!-- Ref ID Base-->
          </op:part>

          <op:part href="SceneBuilder.part.xml" name="LED_SC_NR" instances="64">
            <op:param name="%SZ%" value="0" increment="1" digits="1" /> <!-- Szene number -->
          </op:part>

          <Static>
            <ParameterTypes>
              <ParameterType Id="%AID%_PT-HardwareVariantAB" Name="HardwareVariantAB">
                <TypeRestriction Base="Value" SizeInBit="4">
                  <Enumeration Text="Constant Voltage, Unterputz, 6-fach" Value="0" Id="%ENID%" />
                  <Enumeration Text="Constant Voltage, REG, 12-fach" Value="1" Id="%ENID%" />
                  <Enumeration Text="Constant Current, Unterputz, 8-fach" Value="2" Id="%ENID%" />
                  <Enumeration Text="Constant Current, Unterputz, 16-fach" Value="3" Id="%ENID%" />
                  <Enumeration Text="Constant Current, REG, 12-fach" Value="4" Id="%ENID%" />
                  <!-- 1 bits left -->
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-DimmerCcType" Name="DimmerCcType">
                <TypeRestriction Base="Value" SizeInBit="1" UIHint="DropDown">
                  <Enumeration Text="Hybrides dimmen (analog/PWM)" Value="0" Id="%ENID%" />
                  <Enumeration Text="Reines PWM dimmen" Value="1" Id="%ENID%" />
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-PwmFrequency" Name="PwmFrequency">
                <TypeRestriction Base="Value" SizeInBit="4">
                  <Enumeration Text="200 Hz" Value="0" Id="%ENID%" />
                  <Enumeration Text="400 Hz" Value="1" Id="%ENID%" />
                  <Enumeration Text="600 Hz" Value="2" Id="%ENID%" />
                  <Enumeration Text="800 Hz" Value="3" Id="%ENID%" />
                  <Enumeration Text="1000 Hz" Value="4" Id="%ENID%" />
                  <Enumeration Text="1200 Hz" Value="5" Id="%ENID%" />
                  <!-- 1 bit left -->
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-Lighttype" Name="Lighttype">
                <TypeRestriction Base="Value" SizeInBit="8">
                  <Enumeration Text="Deaktiviert" Value="0" Id="%ENID%" />
                  <Enumeration Text="EK - Einzelkanal" Value="1" Id="%ENID%" />
                  <Enumeration Text="TW - Tunable White" Value="2" Id="%ENID%" />
                  <Enumeration Text="RGB - Rot/Grün/Blau" Value="3" Id="%ENID%" />
                  <!-- <Enumeration Text="RGBW" Value="4" Id="%ENID%" />
                  <Enumeration Text="RGBTW" Value="5" Id="%ENID%" /> -->
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-StartupBehavior" Name="StartupBehavior">
                <TypeRestriction Base="Value" SizeInBit="8">
                  <Enumeration Text="Helligkeit max. Tag/Nacht" Value="0" Id="%ENID%" />
                  <Enumeration Text="Letzter Wert" Value="1" Id="%ENID%" />
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-DimCurve" Name="DimCurve">
                <TypeRestriction Base="Value" SizeInBit="3">
                  <Enumeration Text="Linear" Value="0" Id="%ENID%" />
                  <Enumeration Text="Exponentiell 1.5" Value="1" Id="%ENID%" />
                  <Enumeration Text="Exponentiell 2.0" Value="2" Id="%ENID%" />
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-Percentage" Name="Percentage">
                <TypeNumber SizeInBit="8" Type="signedInt" minInclusive="0" maxInclusive="100" />
              </ParameterType>

              <ParameterType Id="%AID%_PT-SceneType" Name="SceneType">
                <TypeRestriction Base="Value" SizeInBit="3">
                  <Enumeration Text="Deaktiviert" Value="0" Id="%ENID%" />
                  <Enumeration Text="Wert" Value="1" Id="%ENID%" />
                  <!-- hidden for now till actually implemented in firmware
                  <Enumeration Text="Funktion" Value="2" Id="%ENID%" />
                  <Enumeration Text="Ablauf" Value="3" Id="%ENID%" />
                  <Enumeration Text="Sperrobjekt" Value="4" Id="%ENID%" /> -->
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-SceneNumber" Name="Szene">
                <TypeNumber SizeInBit="7" Type="unsignedInt" minInclusive="1" maxInclusive="64" DisplayOffset="1" />
              </ParameterType>

              <ParameterType Id="%AID%_PT-SceneNumberEN" Name="SzeneNr">
                <TypeRestriction Base="Value" SizeInBit="6">
                  <op:usePart name="LED_SC_NR" xpath="//Static/ParameterTypes/ParameterType[@Name='SzeneNrEN']/*" />
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-LockUnlock" Name="Sperren">
                <TypeRestriction Base="Value" SizeInBit="2" UIHint="DropDown">
                  <Enumeration Text="Entsperren" Value="0" Id="%ENID%" />
                  <Enumeration Text="Sperren" Value="1" Id="%ENID%" />
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-LockObject" Name="Sperrobjekt">
                <TypeRestriction Base="Value" SizeInBit="1" UIHint="DropDown">
                  <Enumeration Text="Sperren 1" Value="0" Id="%ENID%" />
                  <Enumeration Text="Sperren 2" Value="1" Id="%ENID%" />
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-TimeFactor" Name="TimeFactor">
                <TypeRestriction Base="Value" SizeInBit="4">
                  <Enumeration Text="0.5" Value="1" Id="%ENID%" />
                  <Enumeration Text="1.0" Value="2" Id="%ENID%" />
                  <Enumeration Text="1.5" Value="3" Id="%ENID%" />
                  <Enumeration Text="2.0" Value="4" Id="%ENID%" />
                  <Enumeration Text="3.0" Value="6" Id="%ENID%" />
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-MinDim" Name="MinDimValue">
                <TypeNumber SizeInBit="8" Type="unsignedInt" minInclusive="0" maxInclusive="127" />
              </ParameterType>

              <ParameterType Id="%AID%_PT-MaxDim" Name="MaxDimValue">
                <TypeNumber SizeInBit="8" Type="unsignedInt" minInclusive="128" maxInclusive="255" />
              </ParameterType>

              <ParameterType Id="%AID%_PT-DimTime" Name="DimTime">
                <TypeNumber SizeInBit="16" Type="unsignedInt" minInclusive="0" maxInclusive="10000" />
              </ParameterType>

              <ParameterType Id="%AID%_PT-MinVoltage" Name="MinVoltage">
                <TypeNumber SizeInBit="8" Type="unsignedInt" minInclusive="0" maxInclusive="48" />
              </ParameterType>

              <ParameterType Id="%AID%_PT-ManualModeChangeToAuto" Name="ManualModeChangeToAuto">
                <TypeRestriction Base="Value" SizeInBit="2" UIHint="DropDown">
                  <Enumeration Text="Deaktiviert" Value="0" Id="%ENID%" />
                  <Enumeration Text="Nach Zeit" Value="1" Id="%ENID%" />
                  <Enumeration Text="Bei langem Tastendruck (> 3 Sek.)" Value="2" Id="%ENID%" />
                  <Enumeration Text="Bei langem Tastendruck (> 3 Sek.) oder nach Zeit" Value="3" Id="%ENID%" />
                </TypeRestriction>
              </ParameterType>

            </ParameterTypes>

            <Parameters>
              <Union SizeInBit="8">
                <Memory CodeSegment="%AID%_RS-04-00000" Offset="0" BitOffset="0" />
                <Parameter Id="%AID%_UP-%TT%00001" Name="HardwareVariantAB"            ParameterType="%AID%_PT-HardwareVariantAB" Offset="0" BitOffset="0" Text="Hardware-Variante" Value="0" />
                <!-- 2 bits free -->
                <Parameter Id="%AID%_UP-%TT%00006" Name="DimmerCcType"                 ParameterType="%AID%_PT-DimmerCcType" Offset="0" BitOffset="6" Text="Dimmart Constant Current" Value="0" />
                <!-- 1 bit free -->
              </Union>
              <Union SizeInBit="8">
                <Memory CodeSegment="%AID%_RS-04-00000" Offset="1" BitOffset="0" />
                <Parameter Id="%AID%_UP-%TT%00007" Name="PwmFrequency"                 ParameterType="%AID%_PT-PwmFrequency" Offset="0" BitOffset="0" Text="PWM-Frequenz" Value="4" />
                <!-- 4 bits free -->
              </Union>
              <Union SizeInBit="32">
                <Memory CodeSegment="%AID%_RS-04-00000" Offset="2" BitOffset="0" />
                <!-- 7 bits free -->
                <Parameter Id="%AID%_UP-%TT%00002" Name="PowerSupplyRelay"             ParameterType="%AID%_PT-OnOffYesNo" Offset="0" BitOffset="7" Text="Externes Netzteil-Relais" Value="0" />
                <Parameter Id="%AID%_UP-%TT%00003" Name="PowerSupplyRelayMinVoltage"   ParameterType="%AID%_PT-MinVoltage" Offset="1" BitOffset="0" Text="Dimmstart bei" Value="46" SuffixText="V" />
                <Parameter Id="%AID%_UP-%TT%00004" Name="PowerSupplyRelayOffDelayBase" ParameterType="%AID%_PT-DelayBase" Offset="2" BitOffset="0" Text="Zeitbasis" Value="0" />
                <Parameter Id="%AID%_UP-%TT%00005" Name="PowerSupplyRelayOffDelayTime" ParameterType="%AID%_PT-DelayTime" Offset="2" BitOffset="2" Text="Zeit" Value="0" />
              </Union>
            </Parameters>

            <ParameterRefs>
              <ParameterRef Id="%AID%_UP-%TT%00001_R-%TT%0000101" RefId="%AID%_UP-%TT%00001" />
              <ParameterRef Id="%AID%_UP-%TT%00002_R-%TT%0000201" RefId="%AID%_UP-%TT%00002" />
              <ParameterRef Id="%AID%_UP-%TT%00003_R-%TT%0000301" RefId="%AID%_UP-%TT%00003" />
              <ParameterRef Id="%AID%_UP-%TT%00004_R-%TT%0000401" RefId="%AID%_UP-%TT%00004" />
              <ParameterRef Id="%AID%_UP-%TT%00005_R-%TT%0000501" RefId="%AID%_UP-%TT%00005" />
              <ParameterRef Id="%AID%_UP-%TT%00006_R-%TT%0000601" RefId="%AID%_UP-%TT%00006" />
              <ParameterRef Id="%AID%_UP-%TT%00007_R-%TT%0000701" RefId="%AID%_UP-%TT%00007" />
            </ParameterRefs>

            <ComObjectTable>
              <ComObject Id="%AID%_O-%TT%00001" Name="PowerSupplyRelay" Number="0" ObjectSize="1 Bit" Text="Externes Netzteil-Relais" FunctionText="Anforderung" ReadFlag="Enabled" WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled" UpdateFlag="Disabled" ReadOnInitFlag="Disabled" DatapointType="DPST-1-1" />
              <ComObject Id="%AID%_O-%TT%00002" Name="PowerSupplyRelayStatus" Number="1" ObjectSize="1 Bit" Text="Externes Netzteil-Relais" FunctionText="Rückmeldung" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Enabled" ReadOnInitFlag="Disabled" DatapointType="DPST-1-1" />
            </ComObjectTable>

            <ComObjectRefs>
              <ComObjectRef Id="%AID%_O-%TT%00001_R-%TT%0000101" RefId="%AID%_O-%TT%00001" />
              <ComObjectRef Id="%AID%_O-%TT%00002_R-%TT%0000201" RefId="%AID%_O-%TT%00002" />
            </ComObjectRefs>

            <Extension>
              <Baggage RefId="%FILE-HELP-de%" />
              <Baggage RefId="%FILE-ICONS%" />
              <Baggage RefId="%FILE-openknx%" />
              <Baggage RefId="%FILE-pics-and%" />
              <Baggage RefId="%FILE-pics-or%" />
            </Extension>
          </Static>

          <Dynamic>
            <Channel Name="MainChannel" Text="Dimmer" Number="%TT%" Id="%AID%_CH-%TT%" HelpContext="Empty" Icon="ceiling-light-multiple">
              <ParameterBlock Id="%AID%_PB-nnn" Name="Settings" Text="Allgemein" Icon="cog-outline" ShowInComObjectTree="true">
                <ParameterSeparator Id="%AID%_PS-nnn" Text="LED-Dimmer" UIHint="Headline" />
                <ParameterSeparator Id="%AID%_PS-nnn" Text="Version: %ModuleVersion%" />
                <ParameterSeparator Id="%AID%_PS-nnn" Text="" UIHint="HorizontalRuler" />

                <choose ParamRefId="%AID%_P-1000099_R-100009901"> <!-- Static 0 -->
                  <when test="!=%HardwareAB%">
                    <ParameterSeparator Id="%AID%_PS-nnn" Text="Hardware" UIHint="Headline" />
                    <ParameterRefRef RefId="%AID%_UP-%TT%00001_R-%TT%0000101" IndentLevel="1" /> <!-- AB-SmartHouse: Hardware Variant -->
                    <ParameterSeparator Id="%AID%_PS-nnn" Text="" UIHint="HorizontalRuler" />
                  </when>
                </choose>

                <ParameterSeparator Id="%AID%_PS-nnn" Text="Kanalzuordnung" UIHint="Headline" />
                <ParameterBlock Id="%AID%_PB-12" Name="Table1ChannelAssignment" Text="Kanal" Inline="true" Layout="Table">
                  <Rows>
                    <op:include href="LEDModule.templ.xml" xpath="//Dynamic/ChannelIndependentBlock/ParameterBlock[@Name='HWChannels']/Rows/*" prefix="LED" type="template" IsInner="true" />
                  </Rows>
                  <Columns>
                    <Column Id="%AID%_PB-12_C-1" Name="Col1" Text="Typ" Width="33%" />
                    <Column Id="%AID%_PB-12_C-2" Name="Col2" Text="Dimmkanal" Width="33%" />
                    <Column Id="%AID%_PB-12_C-3" Name="Col3" Text="Funktion" Width="33%" />
                  </Columns>
                  <op:include href="LEDModule.templ.xml" xpath="//Dynamic/ChannelIndependentBlock/ParameterBlock[@Name='AssignmentTable']/*" prefix="LED" type="template" IsInner="true" />
                </ParameterBlock>

                <choose ParamRefId="%AID%_P-1000099_R-100009901"> <!-- Static 0 -->
                  <when test="!=%HardwareAB%">
                    <ParameterSeparator Id="%AID%_PS-nnn" Text="" UIHint="HorizontalRuler" />
                    <ParameterSeparator Id="%AID%_PS-nnn" Text="Weitere Einstellungen" UIHint="Headline"/>
                    <choose ParamRefId="%AID%_UP-%TT%00001_R-%TT%0000101">
                      <when test="0 1"> <!-- AB-SmartHouse: CV variant -->
                        <ParameterRefRef RefId="%AID%_UP-%TT%00007_R-%TT%0000701" IndentLevel="1" /> <!-- PWM Frequency -->
                      </when>
                      <when test="2 3 4"> <!-- AB-SmartHouse: CC variant -->
                        <ParameterRefRef RefId="%AID%_UP-%TT%00006_R-%TT%0000601" IndentLevel="1" /> <!-- Dimmer CC Type -->
                      </when>
                    </choose>

                    <ParameterRefRef RefId="%AID%_UP-%TT%00002_R-%TT%0000201" IndentLevel="1" /> <!-- Power Supply Relay -->
                    <choose ParamRefId="%AID%_UP-%TT%00002_R-%TT%0000201">
                      <when test="1">
                        <ParameterRefRef RefId="%AID%_UP-%TT%00003_R-%TT%0000301" IndentLevel="2" /> <!-- Power Supply Relay Min Voltage -->
                        
                        <ParameterBlock Id="%AID%_PB-nnn" Inline="true" Layout="Grid"> <!-- Power Supply Relay Off Delay -->
                          <Rows>
                            <Row Id="%AID%_PB-nnn_R-1" Name="Row1" />
                          </Rows>
                          <Columns>
                            <Column Id="%AID%_PB-nnn_C-1" Name="Col1" Width="2%" />
                            <Column Id="%AID%_PB-nnn_C-2" Name="Col2" Width="43%" />
                            <Column Id="%AID%_PB-nnn_C-3" Name="Col3" Width="15%" />
                            <Column Id="%AID%_PB-nnn_C-4" Name="Col4" Width="20%" />
                          </Columns>
                          <ParameterSeparator Id="%AID%_PS-nnn" Text=" Ausschaltverzögerung" Cell="1,2" />
                          <ParameterRefRef RefId="%AID%_UP-%TT%00005_R-%TT%0000501" Cell="1,3" />
                          <ParameterRefRef RefId="%AID%_UP-%TT%00004_R-%TT%0000401" Cell="1,4" />
                        </ParameterBlock>

                        <ComObjectRefRef RefId="%AID%_O-%TT%00001_R-%TT%0000101" />
                        <ComObjectRefRef RefId="%AID%_O-%TT%00002_R-%TT%0000201" />
                      </when>
                    </choose>
                  </when>
                </choose>

                <op:include href="LEDModule.templ.xml" xpath="//Dynamic/ChannelIndependentBlock/ParameterBlock[@Name='FunctionAssignment']/*" prefix="LED" type="template" IsInner="true" />
              </ParameterBlock>

              <op:include href="Single.share.xml" xpath="//Dynamic/ChannelIndependentBlock/*" prefix="LED_SC" />
              <op:include href="TW.share.xml" xpath="//Dynamic/ChannelIndependentBlock/*" prefix="LED_TW" />
              <op:include href="RGB.share.xml" xpath="//Dynamic/ChannelIndependentBlock/*" prefix="LED_RGB" />
            </Channel>

          </Dynamic>

        </ApplicationProgram>
      </ApplicationPrograms>
      <Baggages>
        <Baggage TargetPath="" Name="Icons.zip" Id="%FILE-ICONS%">
          <FileInfo TimeInfo="%DATETIME%" />
        </Baggage>
      </Baggages>
    </Manufacturer>
  </ManufacturerData>
</KNX>