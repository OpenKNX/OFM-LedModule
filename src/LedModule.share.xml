<?xml version="1.0" encoding="utf-8"?>
<?xml-model href="../../Organization/knxprod-support/knx_project_14/knx-editor.xsd" type="application/xml" schematypens="http://www.w3.org/2001/XMLSchema"?>
<KNX xmlns:op="http://github.com/OpenKNX/OpenKNXproducer" xmlns="http://knx.org/xml/project/20" CreatedBy="KNX MT" ToolVersion="5.1.255.16695">
  <ManufacturerData>
    <Manufacturer>
      <ApplicationPrograms>
        <ApplicationProgram>
          <Static>
            <ParameterTypes>

              <ParameterType Id="%AID%_PT-Lighttype" Name="Lighttype">
                <TypeRestriction Base="Value" SizeInBit="8">
                  <Enumeration Text="Deaktiviert" Value="0" Id="%AID%_PT-Lighttype_EN-0" />
                  <Enumeration Text="RGBW" Value="1" Id="%AID%_PT-Lighttype_EN-1" />
                  <Enumeration Text="RGB" Value="2" Id="%AID%_PT-Lighttype_EN-2" />
                  <Enumeration Text="TW" Value="3" Id="%AID%_PT-Lighttype_EN-3" />
                  <Enumeration Text="Einfacher Kanal" Value="4" Id="%AID%_PT-Lighttype_EN-4" />
                </TypeRestriction>
              </ParameterType>

              <ParameterType Id="%AID%_PT-DimmTime" Name="Dimmzeit">
                <TypeNumber SizeInBit="16" Type="unsignedInt" minInclusive="0" maxInclusive="65535" />
              </ParameterType>

              <ParameterType Id="%AID%_PT-ChannelAssignment" Name="Kanal-Zuordnung">
                <TypeRestriction Base="Value" SizeInBit="8">
                  <Enumeration Text="-" Value="99" Id="%AID%_PT-ChannelAssignment_EN-99" />
                  <Enumeration Text="Kanal 1" Value="0" Id="%AID%_PT-ChannelAssignment_EN-0" />
                  <Enumeration Text="Kanal 2" Value="1" Id="%AID%_PT-ChannelAssignment_EN-1" />
                  <Enumeration Text="Kanal 3" Value="2" Id="%AID%_PT-ChannelAssignment_EN-2" />
                  <Enumeration Text="Kanal 4" Value="3" Id="%AID%_PT-ChannelAssignment_EN-3" />
                  <Enumeration Text="Kanal 5" Value="4" Id="%AID%_PT-ChannelAssignment_EN-4" />
                  <Enumeration Text="Kanal 6" Value="5" Id="%AID%_PT-ChannelAssignment_EN-5" />
                </TypeRestriction>
              </ParameterType>


              <ParameterType Id="%AID%_PT-LightColorRGB" Name="LightColorRGB">
                <TypeColor Space="RGB" />
              </ParameterType>

              <ParameterType Id="%AID%_PT-LightColorW" Name="LightColorW">
                <TypeNumber SizeInBit="8" Type="unsignedInt" minInclusive="0" maxInclusive="255" />
              </ParameterType>

              <ParameterType Id="%AID%_PT-LEDChannelBrightness" Name="LEDChannelBrightness">
                <TypeNumber SizeInBit="8" Type="unsignedInt" minInclusive="0" maxInclusive="255" />
              </ParameterType>
            </ParameterTypes>

            <Parameters>
            </Parameters>

            <ParameterRefs>
            </ParameterRefs>

            <ComObjectTable>
            </ComObjectTable>
            <ComObjectRefs>
            </ComObjectRefs>
            <Extension>
              <Baggage RefId="%FILE-HELP-de%" />
              <Baggage RefId="%FILE-ICONS%" />
              <Baggage RefId="%FILE-openknx%" />
              <Baggage RefId="%FILE-pics-and%" />
              <Baggage RefId="%FILE-pics-or%" />
            </Extension>
          </Static>
          <Dynamic>
            <Channel Name="MainChannel" Text="Lichter" Number="%TT%" Id="%AID%_CH-%TT%" Icon="lightbulb-group-outline" HelpContext="Empty">
              <ParameterBlock Id="%AID%_PB-nnn" Name="Documentation" Text="Dokumentation" Icon="information-outline">
                <ParameterSeparator Id="%AID%_PS-nnn" Text="Dokumentation" UIHint="Headline" />
                <ParameterSeparator Id="%AID%_PS-nnn" Text="Bla bla bla" />
              </ParameterBlock>
              <op:include href="./LedModule.templ.xml" xpath="//Dynamic/ChannelIndependentBlock/*" type="template" prefix="LED" IsInner="true"/>
            </Channel>

            <ChannelIndependentBlock>
            </ChannelIndependentBlock>
          </Dynamic>
        </ApplicationProgram>
      </ApplicationPrograms>
      <Baggages>
        <Baggage TargetPath="" Name="Help_de.zip" Id="%FILE-HELP-de%">
          <FileInfo TimeInfo="%DATETIME%" />
        </Baggage>
        <Baggage TargetPath="" Name="Icons.zip" Id="%FILE-ICONS%">
          <FileInfo TimeInfo="%DATETIME%" />
        </Baggage>
      </Baggages>
    </Manufacturer>
  </ManufacturerData>
</KNX>